{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": "\\.e2e-spec\\.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^@libs/common(|/.*)$": "<rootDir>/../../../libs/common/src/$1",
    "^@libs/config(|/.*)$": "<rootDir>/../../../libs/config/src/$1",
    "^@libs/database(|/.*)$": "<rootDir>/../../../libs/database/src/$1",
    "^@libs/error(|/.*)$": "<rootDir>/../../../libs/error/src/$1",
    "^@libs/health(|/.*)$": "<rootDir>/../../../libs/health/src/$1",
    "^@libs/logger(|/.*)$": "<rootDir>/../../../libs/logger/src/$1",
    "^@libs/redis(|/.*)$": "<rootDir>/../../../libs/redis/src/$1",
    "^@libs/swagger(|/.*)$": "<rootDir>/../../../libs/swagger/src/$1",
    "^@libs/http(|/.*)$": "<rootDir>/../../../libs/http/src/$1"
  }
}
